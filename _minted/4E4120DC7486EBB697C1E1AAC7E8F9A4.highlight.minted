\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{decode\PYGZus{}coeff}\PYG{p}{(}\PYG{n}{c}\PYG{p}{,} \PYG{n}{delta}\PYG{p}{,} \PYG{n}{p}\PYG{p}{):}
\PYG{+w}{	}\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{	This function decodes a specific coefficient within the polynomial.}
\PYG{l+s+sd}{	\PYGZsq{}\PYGZsq{}\PYGZsq{}}
	\PYG{c+c1}{\PYGZsh{} divide by delta and round}
	\PYG{n}{decoded\PYGZus{}c} \PYG{o}{=} \PYG{n+nb}{int}\PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{rint}\PYG{p}{(}\PYG{n}{c}\PYG{o}{/}\PYG{n}{delta}\PYG{p}{))}
