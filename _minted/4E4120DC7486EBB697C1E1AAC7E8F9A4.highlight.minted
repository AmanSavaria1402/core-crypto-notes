	\PYG{k}{return} \PYG{n}{out}
	
\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{decode\PYGZus{}rlwe}\PYG{p}{(}\PYG{n}{p}\PYG{p}{:} \PYG{n}{Polynomial}\PYG{p}{,} \PYG{n}{config}\PYG{p}{:} \PYG{n}{RLWEConfig}\PYG{p}{):}
\PYG{+w}{	}\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{	This function decodes the given polynomial to remove the noise and get the final decrypted cleartext.}
