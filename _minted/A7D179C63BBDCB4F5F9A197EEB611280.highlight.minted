\PYG{c+c1}{\PYGZsh{} LWECiphertext Class}
	\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{add\PYGZus{}ciphertext}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{other}\PYG{p}{:} \PYG{n}{LWECiphertext}\PYG{p}{):}
\PYG{+w}{		}\PYG{l+s+sd}{\PYGZsq{}\PYGZsq{}\PYGZsq{}}
\PYG{l+s+sd}{		This function adds a given ciphertext to the current ciphertext and returns a new ciphertext.}
\PYG{l+s+sd}{		\PYGZsq{}\PYGZsq{}\PYGZsq{}}
		\PYG{c+c1}{\PYGZsh{} adding their as and bs}
		\PYG{n}{added\PYGZus{}a} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{add}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{a}\PYG{p}{,} \PYG{n}{other}\PYG{o}{.}\PYG{n}{a}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{int32}\PYG{p}{)}
		\PYG{n}{added\PYGZus{}b} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{add}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{b}\PYG{p}{,} \PYG{n}{other}\PYG{o}{.}\PYG{n}{b}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{int32}\PYG{p}{)}
	
		\PYG{c+c1}{\PYGZsh{} \PYGZsh{} taking mods just to see if this works, but we have to take mod wrt q}
		\PYG{c+c1}{\PYGZsh{} q = config.q}
		\PYG{c+c1}{\PYGZsh{} added\PYGZus{}a = ((added\PYGZus{}a + (q//2)) \PYGZpc{} q) \PYGZhy{} (q//2)}
		\PYG{c+c1}{\PYGZsh{} added\PYGZus{}b = ((added\PYGZus{}b + (q//2)) \PYGZpc{} q) \PYGZhy{} (q//2) \PYGZsh{} im getting overflow errors when doing this}
		
		\PYG{k}{return} \PYG{n}{LWECiphertext}\PYG{p}{(}\PYG{n}{added\PYGZus{}a}\PYG{p}{,} \PYG{n}{added\PYGZus{}b}\PYG{p}{)}
		
